# libraries

import os
import shlex
import subprocess
from snakemake.utils import min_version

min_version("6.4.1")


##### version tracking #####

def find_workflow_directory():
    """
    Find the workflow directory using multiple heuristics.

    When Snakemake loads a Snakefile, __file__ may point to unexpected locations.
    This function tries several methods to find the actual workflow directory.

    Returns:
        tuple: (workflow_dir, project_root) where project_root is parent of workflow/
    """
    cwd = os.getcwd()

    # Method 1: Check current working directory for workflow/Snakefile
    snakefile_in_cwd = os.path.join(cwd, "workflow", "Snakefile")
    if os.path.exists(snakefile_in_cwd):
        return os.path.dirname(snakefile_in_cwd), cwd

    # Method 2: Check if we're already in workflow directory
    snakefile_here = os.path.join(cwd, "Snakefile")
    if os.path.exists(snakefile_here):
        return cwd, os.path.dirname(cwd)

    # Method 3: Walk up from cwd looking for workflow/Snakefile
    search_dir = cwd
    for _ in range(10):  # Max 10 levels up
        candidate = os.path.join(search_dir, "workflow", "Snakefile")
        if os.path.exists(candidate):
            return os.path.dirname(candidate), search_dir
        parent = os.path.dirname(search_dir)
        if parent == search_dir:  # Reached root
            break
        search_dir = parent

    # Method 4: Look for .snakedeploy file which indicates deployment root
    search_dir = cwd
    for _ in range(10):
        snakedeploy_file = os.path.join(search_dir, ".snakedeploy")
        if os.path.exists(snakedeploy_file):
            # Found deployment root, check for workflow/Snakefile
            candidate = os.path.join(search_dir, "workflow", "Snakefile")
            if os.path.exists(candidate):
                return os.path.dirname(candidate), search_dir
        parent = os.path.dirname(search_dir)
        if parent == search_dir:
            break
        search_dir = parent

    # Method 5: Look for .snakemake directory which indicates workflow root
    search_dir = cwd
    for _ in range(10):
        if os.path.exists(os.path.join(search_dir, ".snakemake")):
            candidate = os.path.join(search_dir, "workflow", "Snakefile")
            if os.path.exists(candidate):
                return os.path.dirname(candidate), search_dir
        parent = os.path.dirname(search_dir)
        if parent == search_dir:
            break
        search_dir = parent

    return None, None


def _read_version_file(candidate_dirs):
    """Return the trimmed contents of the first VERSION file found, else None."""
    for d in candidate_dirs:
        if not d:
            continue
        version_file = os.path.join(d, "VERSION")
        if os.path.exists(version_file):
            try:
                with open(version_file) as f:
                    text = f.read().strip()
                if text:
                    return text
            except OSError:
                pass
    return None


def get_workflow_version():
    """
    Get workflow version for tracking.

    Resolution order (first hit wins):
    1. VERSION file next to this Snakefile or at the repo root
       (works for `module + github(tag=...)` deploys, snakedeploy
        with `tag:`, and archived tarballs).
    2. .snakedeploy metadata in cwd / project root — supports both
       legacy `commit` field and `tag` field.
    3. `git rev-parse HEAD` in the workflow / project / cwd tree
       (developer mode, with `-dirty` suffix when uncommitted).
    4. "unknown" fallback.
    """
    # Locate the workflow directory both via __file__ (works inside the
    # snakemake-cache copy of the Snakefile loaded by `module github(...)`)
    # and via the legacy cwd-based heuristics.
    try:
        snakefile_dir = os.path.dirname(os.path.abspath(__file__))
    except NameError:
        snakefile_dir = None
    repo_root_from_file = os.path.dirname(snakefile_dir) if snakefile_dir else None

    workflow_dir, project_root = find_workflow_directory()

    # 1. VERSION file (release-time stamp; CI/Makefile keeps it in sync with tag)
    version = _read_version_file(
        [snakefile_dir, repo_root_from_file, workflow_dir, project_root]
    )
    if version:
        return version

    # 2. .snakedeploy metadata (legacy `commit`, modern `tag`)
    import json
    for d in [project_root, os.getcwd()]:
        if not d:
            continue
        snakedeploy_file = os.path.join(d, ".snakedeploy")
        if os.path.exists(snakedeploy_file):
            try:
                with open(snakedeploy_file) as f:
                    data = json.load(f)
                for key in ("tag", "commit", "branch"):
                    if data.get(key):
                        return str(data[key])
            except (OSError, json.JSONDecodeError):
                pass

    # 3. git rev-parse (developer / git-clone mode)
    for search_dir in [snakefile_dir, repo_root_from_file, workflow_dir, project_root]:
        if not search_dir:
            continue
        try:
            result = subprocess.run(
                ["git", "rev-parse", "HEAD"],
                cwd=search_dir,
                capture_output=True,
                text=True,
                timeout=5,
            )
            if result.returncode == 0:
                commit_sha = result.stdout.strip()
                status_result = subprocess.run(
                    ["git", "status", "--porcelain"],
                    cwd=search_dir,
                    capture_output=True,
                    text=True,
                    timeout=5,
                )
                if status_result.returncode == 0 and status_result.stdout.strip():
                    return f"{commit_sha}-dirty"
                return commit_sha
        except (subprocess.TimeoutExpired, FileNotFoundError):
            pass

    return "unknown"


# Print version at workflow startup
WORKFLOW_VERSION = get_workflow_version()
print(f"\n{'='*60}")
print(f"NanoRNAMod Workflow Version: {WORKFLOW_VERSION}")
print(f"Started at: {__import__('datetime').datetime.now().isoformat()}")
print(f"{'='*60}\n")


